{# This template loops over paasible_stacks.keys() to join stack networks.
   When stacks are added/removed, the file content changes. The docker_compose
   task uses recreate: auto so Traefik will be recreated when this file changes. #}
services:
  traefik:
    image: "traefik:{{ paasible_traefik_version }}"
    container_name: traefik
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    networks:
      - traefik
{% for stack_key in paasible_stacks | dict2items | selectattr('value.skip_net', 'undefined') | map(attribute='key') %}
      - {{ stack_key }}-net
{% endfor %}
    ports:
      - "80:80"
      - "443:443"
      - "127.0.0.1:8080:8080"
{% for item in paasible_entrypoints | dict2items %}
{% if item.value['protocol'] == 'tcp' and item.value['port'] is defined %}
      - "{{ item.value['host'] | default('0.0.0.0') }}:{{ item.value['port'] }}:{{ item.value['port'] }}"
{% endif %}
{% endfor %}
    environment:
      - CF_DNS_API_TOKEN
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik-certs:/certs
      - ./traefik.yml:/traefik.yml:ro
      - ./dynamic:/dynamic:ro
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.dashboard.rule=Host(`{{ paasible_traefik_dashboard_host }}`)"
      - "traefik.http.routers.dashboard.entrypoints=websecure"
      - "traefik.http.routers.dashboard.tls=true"
      - "traefik.http.routers.dashboard.tls.certresolver={{ paasible_tls_resolver }}"
      - "traefik.http.routers.dashboard.service=api@internal"

networks:
  traefik:
    name: traefik
    driver: bridge
{% for stack_key in paasible_stacks | dict2items | selectattr('value.skip_net', 'undefined') | map(attribute='key') %}
  {{ stack_key }}-net:
    external: true
{% endfor %}

volumes:
  traefik-certs:
    name: traefik-certs
